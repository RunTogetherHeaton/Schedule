<gpx creator="StravaGPX" version="1.1" xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd">
 <metadata>
  <name>Whitefield Wander Shorter (through the meadow)</name>
  <desc>Exit the car park turning right onto St Mary's Road. Continue along Rectory Lane and up Whittaker Lane towards Heaton Park Tram Stop. Cross over Bury Old Road and turn left. Turn right onto Heywood Road and then left onto Mount Road and continue straight onto Sandgate Road. At the end turn left onto Thatch Leach Lane. We'll then take the first right onto Stanway Rd and then the 2nd left onto Grayson Ave for a cheeky little scoot through Fusiliers Meadow. Exit the Meadow onto Thatch Leach and run towards Bury New Road crossing safely at the lights and heading straight down Hardman's Road. Cross over the motorway turning left onto Bury New Road and return to the park via St Mary's Road.</desc>
  <author>
   <name>Dale Richards</name>
   <link href="https://www.strava.com/athletes/108724580"/>
  </author>
  <copyright author="OpenStreetMap contributors">
   <year>2020</year>
   <license>https://www.openstreetmap.org/copyright</license>
  </copyright>
  <link href="https://www.strava.com/routes/3423095791205749310"/>
 </metadata>
