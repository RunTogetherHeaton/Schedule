<gpx creator="StravaGPX" version="1.1" xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd">
 <metadata>
  <name>Round the Back Of Tesco's</name>
  <desc>Exit the car park turning left onto St Mary's Rd, cross over Bury New Road and turn right towards the motorway. Take a left onto Church Lane and then right at Church Inn onto Church Drive. Continue running up Church Dr / Arthur St to the end where there are a few steps and a short path leading to West Rd. At the end cut through the left onto Pinfold Dr following it all the way round the back of Tesco's to the motorway roundabout. Cross the motorway taking the little cut through that brings you out on Cross Avenue then around Stanley Aveune and out onto Bury Old Road at the side of Kirkhams. Run down BOR all the way to the Ostrich pub. Turn right onto Ostrich Lane then fourth right onto Bent Lane returning back to the Park via Rectory Lane.</desc>
  <author>
   <name>Dale Richards</name>
   <link href="https://www.strava.com/athletes/108724580"/>
  </author>
  <copyright author="OpenStreetMap contributors">
   <year>2020</year>
   <license>https://www.openstreetmap.org/copyright</license>
  </copyright>
  <link href="https://www.strava.com/routes/3491164042725522334"/>
 </metadata>
